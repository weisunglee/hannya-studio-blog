---
import type { HTMLAttributes } from "astro/types";
import { getEntry } from "astro:content";
import Socials from "./Socials.astro";
import { useTranslations } from "@/i18n";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();
const footer = await getEntry("pages", "footer");

if (!footer) {
  throw new Error(
    "Missing content entry: `footer.md` or `footer.mdx` in `src/content/pages/`"
  );
}

const copyrightLabel = footer.data.copyrightLabel ?? t.footer.copyright;
const rightsText = footer.data.rightsText ?? t.footer.allRightsReserved;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="border-border flex flex-col items-center justify-between border-t py-6 sm:flex-row-reverse sm:py-4"
  >
    <Socials />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:flex-row">
      <span>{copyrightLabel} &#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>{rightsText}</span>
    </div>
  </div>
</footer>
